# ============================================================
# MrCeesAI Voice Demo — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ---- RETELL AI (REQUIRED) ----
# Get from: https://dashboard.retellai.com/settings/api-keys
RETELL_API_KEY=your_retell_api_key_here

# Your Retell Agent ID (the MrCeesAI-Demo agent)
# Found in: https://dashboard.retellai.com/agents
RETELL_AGENT_ID=agent_419c1065694c58b9aa7d691a60

# ---- MAKE.COM (OPTIONAL - for automation) ----
# Create a webhook scenario in Make.com and paste the URL here
MAKE_WEBHOOK_URL=https://hook.us1.make.com/your_webhook_id

# ---- TWILIO (OPTIONAL - for SMS) ----
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+12764479695

# ---- SUPABASE (OPTIONAL - for lead storage) ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# ---- APP CONFIG ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEMO_PHONE=+12764479695
